{
  "version": "1.0",
  "project": {
    "name": "the-indian-water-tanker",
    "framework": "nextjs",
    "language": "typescript",
    "capacitor": true
  },
  "structure": {
    "routes": "src/app",
    "components": "src/components",
    "hooks": "src/hooks",
    "services": "src/services",
    "store": "src/store",
    "types": "src/types",
    "utils": "src/utils",
    "constants": "src/constants/index.ts",
    "envAccessor": "src/constants/env.ts",
    "cssTokens": "src/styles/tokens.css",
    "globalStyles": "src/styles/globals.css",
    "locales": "src/locales"
  },
  "rules": {
    "noDuplication": true,
    "noMagicStrings": true,
    "noHardcodedEnvVars": true,
    "noInlineSharedTypes": true,
    "noApiCallsOutsideServices": true,
    "noLogicInRouteFiles": true,
    "namedExportsOnly": true,
    "noPropsTypesInline": false,
    "noBusinessLogicInUI": true,
    "noHardcodedUIStrings": true
  },
  "typescript": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "components": {
    "style": "arrow-function",
    "propsInterface": "required",
    "exportStyle": "named"
  },
  "state": {
    "library": "zustand",
    "storeDir": "src/store"
  },
  "i18n": {
    "library": "next-intl",
    "locales": ["en", "hi"],
    "defaultLocale": "en",
    "localeDir": "src/locales",
    "persistKey": "tiwt_language"
  },
  "capacitorConstraints": {
    "enabled": true,
    "staticExport": true,
    "noSSR": true,
    "noAPIRoutes": true,
    "noMiddleware": true,
    "noServerComponents": true,
    "dataFetching": "client-side-only",
    "backendBaseUrl": "SUPABASE_PROJECT_URL"
  }
}
